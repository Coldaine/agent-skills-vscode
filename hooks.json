{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash scripts/session-start.sh",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash scripts/sdd-cache-pre.sh",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash scripts/sdd-cache-post.sh",
        "timeout": 10
      }
    ]
  }
}
